# LINE Bot
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Supabase：Project Settings → Database → Connection string（URI）
# Render 部署建議用「Session pooler」或「Transaction」的 URI（*.pooler.supabase.com:6543），
# 較不易遇到 IPv6 連線問題；並加上 sslmode=require，例如：
# DATABASE_URL=postgresql://postgres.xxxx:密碼@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
# 若用 direct（db.xxx.supabase.co:5432），程式在 Render 上會自動加上 IPv4 hostaddr。
# 請勿把 project ref 寫進主機名的方括號（錯誤範例：@[Godwin30116002].xxx），
# 應使用 Supabase 畫面複製的完整 URI（使用者名常為 postgres.xxxxx，主機為 aws-0-...pooler 或 db....supabase.co）。
# 未設定 DATABASE_URL 時使用本機 SQLite（diet_tracker.db）
# DATABASE_URL=
# 在 Render 上若要關閉自動 IPv4 改寫：DATABASE_FORCE_IPV4=0
# DATABASE_FORCE_IPV4=

# GitHub Actions 呼叫 POST /cron/daily-summary 時的共享密鑰（請與 repo Secrets 的 CRON_SECRET 一致）
# CRON_SECRET=

# 設為 1 時由程式內每晚 23:00 推播（一般請留空，改由 GitHub Actions 觸發）
# ENABLE_INTERNAL_DAILY_CRON=0

# Render 會自動注入 PORT；本機可選
# PORT=8000
