# LINE Bot
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
# 單次 OpenAI 請求逾時秒數（避免卡太久）
# OPENAI_TIMEOUT_SEC=90
# OpenAI 呼叫重試次數（建議 2~4）
# OPENAI_MAX_RETRIES=3
# 單次下載 LINE 圖片逾時秒數
# LINE_IMAGE_TIMEOUT_SEC=20
# 下載 LINE 圖片重試次數
# LINE_IMAGE_MAX_RETRIES=3
# 背景圖片分析總逾時（包含下載/重試/AI）
# IMAGE_ANALYSIS_TIMEOUT_SEC=120

# Supabase：Project Settings → Database → Connection string（URI）
# Render 建議貼 Supabase Connect 的「Session pooler」URI（*.pooler.supabase.com:5432，使用者 postgres.<project_ref>）。
# 若 DATABASE_URL 誤用使用者「postgres」連 pooler，請在 Render 加：
#   SUPABASE_PROJECT_REF=你的_project_ref（與使用者 postgres. 後面那段相同）
# 程式會自動改試 postgres.<ref> @ 5432。
# 若你使用的是 Shared/Transaction pooler，可另外指定：
#   SUPABASE_POOLER_PORT=6543
# Transaction pooler 為 port 6543、使用者 postgres（與 Session 不同，勿混到 5432）。
# 並建議 sslmode=require，例如：
# DATABASE_URL=postgresql://postgres.xxxxx:密碼@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
# 若用 direct（db.xxx.supabase.co:5432）：若該主機沒有 IPv4（常見），在 Render 請設：
#   SUPABASE_REGION=ap-south-1
# （請改成你專案在 Supabase 儀表板顯示的區域，例如 Primary Database 在 Mumbai 即 ap-south-1）
# 程式會自動改連 Session pooler（*.pooler.supabase.com:5432，使用者 postgres.<ref>）。
# 或直接貼 Supabase Connect 裡的「Session pooler」URI 當 DATABASE_URL。
# 請勿把 project ref 寫進主機名的方括號（錯誤範例：@[Godwin30116002].xxx），
# 應使用 Supabase 畫面複製的完整 URI（使用者名常為 postgres.xxxxx，主機為 aws-0-...pooler 或 db....supabase.co）。
# 未設定 DATABASE_URL 時使用本機 SQLite（diet_tracker.db）
# DATABASE_URL=
# 在 Render 上若要關閉自動 IPv4 改寫：DATABASE_FORCE_IPV4=0
# DATABASE_FORCE_IPV4=
# PostgreSQL 連不上時是否允許啟動時自動降級 SQLite（Render 預設僅在 Tenant not found 會啟用）
# DB_STARTUP_ALLOW_SQLITE_FALLBACK=1

# GitHub Actions 呼叫 POST /cron/daily-summary 時的共享密鑰（請與 repo Secrets 的 CRON_SECRET 一致）
# CRON_SECRET=

# 設為 1 時由程式內每晚 23:00 推播（一般請留空，改由 GitHub Actions 觸發）
# ENABLE_INTERNAL_DAILY_CRON=0

# 用餐提醒：預設啟用（進程內 12:30、20:00，時區見 BOT_TIMEZONE）。設為 0 可關閉。
# ENABLE_INTERNAL_MEAL_REMINDERS=0
# 提醒判斷與排程使用的時區（預設台北）
# BOT_TIMEZONE=Asia/Taipei

# Notion 同步（Integration 須連結兩個 Database；欄位名需與 Notion 一致）
# NOTION_TOKEN=secret_xxx
# NOTION_DAILY_DB_ID=
# NOTION_INBODY_DB_ID=
# 每日／InBody 資料庫的「第一欄 Title」在 API 裡的名稱（英文介面常為 Name；預設分別為 日期、檢測日期）
# NOTION_DAILY_TITLE_PROP=Name
# NOTION_INBODY_TITLE_PROP=Name
# 你的 LINE userId（長字串）；建議設定。未設定時會允許所有使用者同步 Notion
# NOTION_SYNC_USER_ID=

# Render 會自動注入 PORT；本機可選
# PORT=8000
